{
    "allowed_paths": [
        "src/.*",
        "app/.*",
        "apps/.*",
        "backend/.*",
        "frontend/.*",
        "server/.*",
        "client/.*",
        "api/.*",
        "web/.*",
        "packages/.*",
        "services/.*",
        "lib/.*",
        "libs/.*",
        "utils/.*",
        "helpers/.*",
        "components/.*",
        "pages/.*",
        "routes/.*",
        "models/.*",
        "views/.*",
        "controllers/.*",
        "middleware/.*",
        "db/.*",
        "database/.*",
        "migrations/.*",
        "tests/.*",
        "test/.*",
        "spec/.*",
        "docs/.*",
        "public/.*",
        "static/.*",
        "assets/.*",
        "templates/.*",
        "scripts/.*",
        "config/.*",
        "infra/.*",
        "ops/.*",
        "docker/.*",
        "deploy/.*",
        "\\.github/.*",
        "README.md",
        "LICENSE.*",
        "pyproject.toml",
        "setup\\.py",
        "setup\\.cfg",
        "requirements.*\\.txt",
        "package\\.json",
        "package-lock\\.json",
        "pnpm-lock\\.yaml",
        "yarn\\.lock",
        "tsconfig\\.json",
        "vite\\.config\\.[jt]s",
        "tailwind\\.config\\.[jt]s",
        "postcss\\.config\\.[jt]s",
        "next\\.config\\.[jt]s",
        "\\.eslintrc.*",
        "\\.prettierrc.*",
        "Cargo\\.toml",
        "Cargo\\.lock",
        "go\\.mod",
        "go\\.sum",
        "Gemfile",
        "Gemfile\\.lock",
        "Makefile",
        "Dockerfile",
        "docker-compose\\.ya?ml",
        "\\.dockerignore",
        "\\.gitignore",
        "Procfile",
        "render\\.yaml",
        "railway\\.toml",
        "vercel\\.json",
        "fly\\.toml",
        "main\\.py",
        "manage\\.py",
        "server\\.py",
        "index\\.[jt]sx?",
        "index\\.html",
        "index\\.css",
        "\\.env\\.example",
        "\\.env\\.sample"
    ],
    "blocked_paths": [
        "^\\.env$",
        "^.*\\/\\.env$",
        "\\.env\\.local",
        "\\.env\\.production",
        "\\.env\\.development",
        "\\.ssh/.*",
        "\\.aws/.*",
        "\\.gnupg/.*",
        "\\.kube/.*",
        "\\.git/.*",
        "\\.npmrc",
        "\\.pypirc",
        "config/secrets\\.json",
        "config/credentials\\.json",
        ".*/\\.bash_history",
        "/etc/.*",
        "/var/.*",
        "/private/.*",
        "/System/.*"
    ],
    "blocked_patterns": [
        "eval\\(",
        "exec\\(",
        "os\\.system\\(",
        "subprocess\\.run\\(",
        "__import__",
        "getattr\\(",
        "setattr\\(",
        "importlib\\."
    ],
    "shell_blocked_patterns": [
        "curl\\s+.*\\|\\s*(?:sh|bash)",
        "wget\\s+.*\\|\\s*(?:sh|bash)",
        "nc\\s+-e",
        "\\brm\\s+-rf\\s+/[^.]",
        "chmod\\s+777",
        "mkfifo.*\\/dev\\/tcp",
        "base64\\s+-d.*\\|\\s*(?:sh|bash)"
    ]
}
